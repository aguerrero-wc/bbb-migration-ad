# === BigBlueButton ===
BBB_SERVER_URL=https://your-bbb-server.com/bigbluebutton/
BBB_SECRET=your-bbb-shared-secret

# === Database (Docker + App) ===
POSTGRES_USER=bbb_admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=bbb_management
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://bbb_admin:change_me_in_production@localhost:5432/bbb_management

# === JWT ===
JWT_SECRET=generate-a-strong-random-secret-here
JWT_REFRESH_SECRET=generate-another-strong-random-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# === Legacy Integration ===
LEGACY_API_URL=https://www.myzonego.com
LEGACY_API_KEY=your-legacy-api-key

# === App ===
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
FRONTEND_PORT=3000
BACKEND_PORT=4000
BCRYPT_ROUNDS=12
